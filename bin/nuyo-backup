#!/usr/bin/env bash
BACKUP_DIR="$HOME/Backups/nuyo-$(date +%Y-%m-%d_%H-%M-%S)"

mkdir -p "$BACKUP_DIR"

cp -r ~/.config "$BACKUP_DIR/config"
cp -r ~/.local/bin "$BACKUP_DIR/bin"
cp ~/.bashrc "$BACKUP_DIR/" 2>/dev/null
cp ~/.zshrc "$BACKUP_DIR/" 2>/dev/null

echo "Backup created at:"
echo "$BACKUP_DIR"

